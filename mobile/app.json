{
  "expo": {
    "name": "Oromo Legacy Wall",
    "slug": "oromo-legacy-wall",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0e0a06"
    },
    "scheme": "oromo-legacy",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.oromolegacy.wall",
      "buildNumber": "1",
      "minimumOsVersion": "16.0",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "Allow Oromo Legacy Wall to access your photos to add a portrait when submitting a hero record.",
        "NSCameraUsageDescription": "Allow Oromo Legacy Wall to use your camera to capture a portrait when submitting a hero record.",
        "ITSAppUsesNonExemptEncryption": false
      },
      "privacyManifests": {
        "NSPrivacyTracking": false,
        "NSPrivacyTrackingDomains": [],
        "NSPrivacyCollectedDataTypes": [],
        "NSPrivacyAccessedAPITypes": []
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0e0a06",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.oromolegacy.wall",
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Oromo Legacy Wall to access your photos to add a portrait when submitting a hero record.",
          "cameraPermission": "Allow Oromo Legacy Wall to use your camera to capture a portrait."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "e3b9f8e1-505e-4430-a1db-73eccd790d76"
      }
    },
    "owner": "fantoli"
  }
}
