{
  "cli": {
    "version": ">= 16.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "distribution": "internal",
      "ios": {
        "simulator": false
      }
    },
    "production": {
      "autoIncrement": true,
      "ios": {
        "resourceClass": "m-medium"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "language": "en-US",
        "appleId": "FILL_IN_YOUR_APPLE_ID",
        "ascAppId": "FILL_IN_APP_STORE_CONNECT_APP_ID",
        "appleTeamId": "FILL_IN_YOUR_TEAM_ID"
      }
    }
  }
}
